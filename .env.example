DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
GITHUB_REPO_OWNER = "YOUR_GITHUB_USERNAME"
GITHUB_REPO_NAME = "YOUR_GITHUB_REPO_NAME"
GITHUB_PAT = "YOUR_GITHUB_PAT" #needed to access github api
PARENT_FOLDER = "CTF-writeups" #default reun10n github

# =============================================================================
# AI AGENT (Kuro)
# =============================================================================
BONSAI_API_KEY="YOUR_BONSAI_API_KEY"

# Primary model (Anthropic-compatible proxy)
AGENT_API_KEY="YOUR_API_KEY"
AGENT_BASE_URL="https://gpt.mirbuds.com/claudecode"
AGENT_MODEL="claude-sonnet-4-20250514"

# Fallback model (OpenRouter - used when primary fails)
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
FALLBACK_BASE_URL="https://openrouter.ai/api/v1"
FALLBACK_MODEL="nvidia/nemotron-3-nano-30b-a3b:free"

# =============================================================================
# TWITTER / X  (required for real-time tweet search)
# Get these from DevTools → Application → Cookies → x.com after logging in
# =============================================================================
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here

# =============================================================================
# OPTIONAL: Owner Discord user ID for DM notifications (e.g. Twitter token expiry)
# Enable Developer Mode in Discord → right-click your name → Copy User ID
# =============================================================================
# OWNER_DISCORD_ID=your_18_digit_discord_user_id
